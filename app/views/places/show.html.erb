<div class="mb-4">
  <a href="/places" class="text-muted text-decoration-none small">
    <i class="bi bi-arrow-left me-1"></i> All Places
  </a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><i class="bi bi-geo-alt me-1"></i> <%= @place["name"] %></h1>
  <% if @current_user != nil %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-dark">
      <i class="bi bi-plus-lg me-1"></i> New Entry
    </a>
  <% end %>
</div>

<h5 class="text-muted mb-3">My Entries</h5>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% for entry in @entries %>
    <div class="col">
      <div class="card h-100 border-0 shadow-sm">
        <% if entry.uploaded_image.attached? %>
          <img src="<%= url_for(entry.uploaded_image) %>" class="card-img-top">
        <% end %>
        <div class="card-body">
          <h5 class="card-title"><%= entry["title"] %></h5>
          <p class="text-muted small mb-2">
            <i class="bi bi-calendar-event me-1"></i> <%= entry["occurred_on"] %>
          </p>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>