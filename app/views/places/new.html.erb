<div class="mb-4">
  <a href="/places" class="text-muted text-decoration-none small">
    <i class="bi bi-arrow-left me-1"></i> All Places
  </a>
</div>

<h1 class="mb-4">New Place</h1>

<div class="row">
  <div class="col-md-6">
    <form action="/places" method="post">
      <div class="mb-3">
        <label for="name_input" class="form-label">Name</label>
        <input type="text" name="name" id="name_input" class="form-control">
      </div>
      <button class="btn btn-dark">
        <i class="bi bi-check-lg me-1"></i> Save
      </button>
    </form>
  </div>
</div>